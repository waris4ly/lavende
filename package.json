{
  "name": "lavende",
  "version": "0.1.0",
  "description": "In-process Discord voice connection and playback engine",
  "main": "npm/index.js",
  "types": "npm/index.d.ts",
  "author": "Debauchery Party",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/debaucheryparty/lavende.git"
  },
  "keywords": [
    "discord",
    "voice",
    "audio",
    "music",
    "lavalink",
    "bot",
    "streaming",
    "opus",
    "napi",
    "rust"
  ],
  "files": [
    "npm",
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "name": "lavende",
    "cargoFilePath": "rust/Cargo.toml",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release --cargo-cwd rust",
    "build:debug": "napi build --platform --cargo-cwd rust",
    "prepublishOnly": "napi prepublish -t npm --cargo-cwd rust",
    "version": "napi version",
    "artifacts": "napi artifacts --cargo-cwd rust"
  },
  "engines": {
    "node": ">= 16"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^26.0.1",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "lavende-darwin-x64": "0.1.0",
    "lavende-darwin-arm64": "0.1.0",
    "lavende-linux-x64-gnu": "0.1.0",
    "lavende-linux-arm64-gnu": "0.1.0",
    "lavende-win32-x64-msvc": "0.1.0"
  }
}
