{
  "name": "lavende",
  "version": "0.1.14",
  "description": "In-process Discord voice connection and playback engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Debauchery Party",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/debaucheryparty/lavende.git"
  },
  "keywords": [
    "discord",
    "voice",
    "audio",
    "music",
    "lavalink",
    "bot",
    "streaming",
    "opus",
    "napi",
    "rust"
  ],
  "files": [
    "dist",
    "index.js",
    "index.d.ts",
    "index.js.map",
    "*.node"
  ],
  "napi": {
    "name": "lavende",
    "cargoFilePath": "Cargo.toml",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:ts": "tsc"
  },
  "engines": {
    "node": ">= 16"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^26.0.1",
    "typescript": "^5.4.0"
  }
}
